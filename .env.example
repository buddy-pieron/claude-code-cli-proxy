# Claude Code CLI Proxy configuration
# Copy this to .env and adjust as needed

# Host to bind to (default: 127.0.0.1, use 0.0.0.0 for all interfaces)
CLAUDE_PROXY_HOST=127.0.0.1

# Port to listen on
CLAUDE_PROXY_PORT=8070

# Optional API key to protect the proxy (leave empty to disable auth)
CLAUDE_PROXY_API_KEY=

# Path to claude binary (auto-detected if on PATH)
CLAUDE_BIN=

# Max concurrent CLI processes (2 for Max sub, 1 for Pro)
CLAUDE_PROXY_MAX_CONCURRENT=2

# Seconds to wait for first output from CLI (increase for Opus with large contexts)
CLAUDE_PROXY_FIRST_CHUNK_TIMEOUT=180

# Seconds to wait between output chunks before considering the stream dead
CLAUDE_PROXY_IDLE_TIMEOUT=120
