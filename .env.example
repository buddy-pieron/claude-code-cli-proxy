# Claude Code Proxy configuration
# Copy this to .env and adjust as needed

# Host to bind to (default: 127.0.0.1, use 0.0.0.0 for all interfaces)
CLAUDE_PROXY_HOST=127.0.0.1

# Port to listen on
CLAUDE_PROXY_PORT=8070

# Optional API key to protect the proxy (leave empty to disable auth)
CLAUDE_PROXY_API_KEY=

# Path to claude binary (auto-detected if on PATH)
CLAUDE_BIN=
